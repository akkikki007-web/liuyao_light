# ============================================================
# Python
# ============================================================

__pycache__/
*.py[cod]
*$py.class

.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
.coverage.*
.cache/

# Build / packaging
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# ============================================================
# Virtual environments
# ============================================================

.venv/
venv/
env/
ENV/

# ============================================================
# uv
# ============================================================

# uv.lock は再現性のため Git 管理する
# uv.lock

# ============================================================
# Environment variables / secrets
# ============================================================

.env
.env.*
!.env.example

# ============================================================
# SQLite / local databases
# ============================================================

data/*.db
data/*.sqlite
data/*.sqlite3

# ただし、マスターデータCSVはGit管理する
!data/master/
!data/master/*.csv
!data/master/*.md

# ============================================================
# User media / private images
# ============================================================

media/originals/*
media/thumbnails/*

# keep directories
!media/originals/.gitkeep
!media/thumbnails/.gitkeep

# ============================================================
# Generated outputs
# ============================================================

outputs/case_images/*
outputs/market_charts/*
outputs/markdown/*
outputs/exports/*

# keep directories
!outputs/case_images/.gitkeep
!outputs/market_charts/.gitkeep
!outputs/markdown/.gitkeep
!outputs/exports/.gitkeep

# ============================================================
# Backups / logs
# ============================================================

backups/
logs/

# ============================================================
# Local imports / private legacy data
# ============================================================

# 旧六爻ツール本体は legacy/liuyao-tool/ に置いてGit管理してよい
# ただし、実占例JSONなどの個人データは除外する
legacy/**/*.json
legacy/**/*.db
legacy/**/*.sqlite
legacy/**/*.sqlite3

# ============================================================
# Sample/private data
# ============================================================

private/
local/
tmp/
temp/

*.bak
*.backup

# ============================================================
# OS files
# ============================================================

.DS_Store
Thumbs.db
desktop.ini

# ============================================================
# Editor / IDE
# ============================================================

.vscode/
.idea/

# 必要ならVS Code設定を共有する場合は、上の .vscode/ を外し、
# 共有したいファイルだけ個別に管理する
# !.vscode/settings.json
# !.vscode/extensions.json

# ============================================================
# Jupyter
# ============================================================

.ipynb_checkpoints/

# ============================================================
# Test / coverage reports
# ============================================================

coverage.xml
junit.xml

# ============================================================
# Misc
# ============================================================

*.log
*.tmp